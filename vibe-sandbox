#!/usr/bin/env bash

# Generate a 5-character random string
RANDOM_STRING=$(tr -dc 'a-z0-9' < /dev/urandom | head -c 5)

# Create .vibe-sandbox directory with proper permissions if it doesn't exist
VIBE_SANDBOX_DIR="${HOME}/.vibe-sandbox"
if [ ! -d "$VIBE_SANDBOX_DIR" ]; then
  mkdir -p "$VIBE_SANDBOX_DIR"
  chmod 700 "$VIBE_SANDBOX_DIR"
fi

# Get current user's UID and GID for proper container process execution
CURRENT_UID=$(id -u)
CURRENT_GID=$(id -g)

# Process --mount arguments
MOUNT_ARGS=()
CONTAINER_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --mount)
      MOUNT_ARGS+=("-v" "$2")
      shift 2
      ;;
    *)
      CONTAINER_ARGS+=("$1")
      shift
      ;;
  esac
done

# Get current working directory for default workspace mount
CURRENT_PWD=$(pwd)

docker run \
  --rm \
  --name vibe-sandbox-${RANDOM_STRING} \
  --security-opt no-new-privileges=true \
  --cpus 2.0 \
  --memory 1G \
  --pull "always" \
  -it \
  -v "${CURRENT_PWD}:/workspace" \
  -v "${VIBE_SANDBOX_DIR}:/home/vibe-user/.vibe" \
  -v /etc/localtime:/etc/localtime:ro \
  -v /etc/timezone:/etc/timezone:ro \
  "${MOUNT_ARGS[@]}" \
  -e HOST_UID="$CURRENT_UID" \
  -e HOST_GID="$CURRENT_GID" \
  nachtsieb/vibe-sandbox:latest \
  "${CONTAINER_ARGS[@]}"
